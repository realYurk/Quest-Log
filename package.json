{
  "name": "personal-walkthrough",
  "version": "1.0.0",
  "description": "A game-like self skill tree & action-driven SOP management tool — your ultimate guide to conquering life's challenges",
  "author": "Quest Log Team",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "vite --mode mobile",
    "build": "vue-tsc && vite build",
    "build:mobile": "vue-tsc && vite build --mode mobile",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "build:all": "npm run build && electron-builder --win --mac --linux",
    "dist": "npm run build:win",
    "--- Mobile Build ---": " ",
    "android:init": "npm run build:mobile && npx cap init 'Life SOP' 'com.lifesop.app' --web-dir=dist",
    "android:add": "npx cap add android",
    "android:sync": "npx cap sync android",
    "android:build": "npm run build:mobile && npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "npm run android:build && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/splash-screen": "^6.0.0",
    "highlight.js": "^11.9.0",
    "mermaid": "^10.9.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "@types/node": "^20.11.24",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^42.4.0",
    "electron-builder": "^24.13.3",
    "playwright": "^1.60.0",
    "postcss": "^8.4.35",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "vue-tsc": "^2.0.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.personalwalkthrough.app",
    "productName": "Quest Log",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/test/**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Quest Log"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon-256.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon-256.png",
      "category": "Utility"
    },
    "extraResources": []
  }
}
